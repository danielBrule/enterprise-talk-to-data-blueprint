# ── Azure SQL ─────────────────────────────────────────────────────────────────
# Connection details for the Azure SQL database containing the analytics views.
AZURE_SQL_SERVER=your-server.database.windows.net,1433
AZURE_SQL_DATABASE=your-database
AZURE_SQL_USERNAME=your-username
AZURE_SQL_PASSWORD=your-password
AZURE_SQL_DRIVER=ODBC Driver 18 for SQL Server

# ── Azure OpenAI ──────────────────────────────────────────────────────────────
# One endpoint, three task-specific deployments.
# Retrieve endpoint and deployment names from Terraform outputs after provisioning:
#   terraform -chdir=src/infra/terraform output
AZURE_OPENAI_ENDPOINT=https://your-account.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key
AZURE_OPENAI_API_VERSION=2024-06-01

# Intent classification and view selection (lightweight model recommended)
AZURE_OPENAI_SCHEMA_RETRIEVAL_DEPLOYMENT=talk2data-gpt41mini-schema-retrieval

# SQL query generation (reasoning-capable model recommended)
# Note: previously named AZURE_OPENAI_RESPONSE_FORMAT_DEPLOYMENT in older versions
AZURE_OPENAI_SQL_GENERATION_DEPLOYMENT=talk2data-gpt41mini-sql-generation

# Natural language answer generation
AZURE_OPENAI_SUMMARY_DEPLOYMENT=talk2data-gpt41mini-summary

# ── Application ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Timeouts ──────────────────────────────────────────────────────────────────
# SQL_QUERY_TIMEOUT_SECONDS: per-statement timeout enforced at the pyodbc cursor level (default 30)
# LLM_TIMEOUT_SECONDS: per-LLM-call timeout applied to the Azure OpenAI client (default 60)
# PIPELINE_TIMEOUT_SECONDS: end-to-end timeout for the full question-to-answer pipeline (default 120)
SQL_QUERY_TIMEOUT_SECONDS=30
LLM_TIMEOUT_SECONDS=60
PIPELINE_TIMEOUT_SECONDS=120

# ── Input safety ──────────────────────────────────────────────────────────────
# MAX_QUESTION_LENGTH: maximum characters allowed in a user question (default 1000)
MAX_QUESTION_LENGTH=1000

# ── Cost control ───────────────────────────────────────────────────────────────
# MAX_TOKENS_PER_REQUEST: maximum total tokens (prompt + completion) across all LLM calls
# in a single pipeline run. The pipeline refuses early if this budget is exceeded.
# Set to 0 to disable the limit (default 10000; a typical question uses 3000–8000 tokens).
MAX_TOKENS_PER_REQUEST=10000
#
# MAX_SQL_RETRIES: number of additional SQL generation attempts when validation fails.
# Total attempts = 1 + MAX_SQL_RETRIES. Each retry feeds the validation error back to
# the LLM as a correction hint. Set to 0 to disable retries (fail immediately).
MAX_SQL_RETRIES=2

# ── Trace store ────────────────────────────────────────────────────────────────
# TRACE_FILE: path for the JSONL file where every pipeline run is appended.
# In production, swap TraceStore._write() for an Azure SQL INSERT or an
# Application Insights custom event — this path setting then becomes irrelevant.
TRACE_FILE=traces/pipeline_traces.jsonl
#
# TRACE_ANONYMIZE: when true, SHA-256-hashes the question and drops user_context
# before writing. Default false — this system handles internal analytics queries
# with no personal data. Enable in domains where questions could carry PII
# (HR, finance, customer data). For richer anonymisation, plug in Microsoft
# Presidio or Azure AI Language at PiiFilter.apply() in app/core/pii_filter.py.
TRACE_ANONYMIZE=false
#
# PIPELINE_ENV: stamped on every trace record so eval and dev runs can be filtered
# out of production analytics without changing TraceRecord itself.
# Values: api (live endpoint, default), eval (set automatically by make eval), local (dev testing).
PIPELINE_ENV=api
