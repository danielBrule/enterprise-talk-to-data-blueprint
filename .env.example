# ── Azure SQL ─────────────────────────────────────────────────────────────────
# Connection details for the Azure SQL database containing the analytics views.
AZURE_SQL_SERVER=your-server.database.windows.net,1433
AZURE_SQL_DATABASE=your-database
AZURE_SQL_USERNAME=your-username
AZURE_SQL_PASSWORD=your-password
AZURE_SQL_DRIVER=ODBC Driver 18 for SQL Server

# ── Azure OpenAI ──────────────────────────────────────────────────────────────
# One endpoint, three task-specific deployments.
# Retrieve endpoint and deployment names from Terraform outputs after provisioning:
#   terraform -chdir=src/infra/terraform output
AZURE_OPENAI_ENDPOINT=https://your-account.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key
AZURE_OPENAI_API_VERSION=2024-06-01

# Intent classification and view selection (lightweight model recommended)
AZURE_OPENAI_SCHEMA_RETRIEVAL_DEPLOYMENT=talk2data-gpt41mini-schema-retrieval

# SQL query generation (reasoning-capable model recommended)
# Note: previously named AZURE_OPENAI_RESPONSE_FORMAT_DEPLOYMENT in older versions
AZURE_OPENAI_SQL_GENERATION_DEPLOYMENT=talk2data-gpt41mini-sql-generation

# Natural language answer generation
AZURE_OPENAI_SUMMARY_DEPLOYMENT=talk2data-gpt41mini-summary

# ── Application ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Timeouts ──────────────────────────────────────────────────────────────────
# SQL_QUERY_TIMEOUT_SECONDS: per-statement timeout enforced at the pyodbc cursor level (default 30)
# LLM_TIMEOUT_SECONDS: per-LLM-call timeout applied to the Azure OpenAI client (default 60)
# PIPELINE_TIMEOUT_SECONDS: end-to-end timeout for the full question-to-answer pipeline (default 120)
SQL_QUERY_TIMEOUT_SECONDS=30
LLM_TIMEOUT_SECONDS=60
PIPELINE_TIMEOUT_SECONDS=120
