# ── Required ──────────────────────────────────────────────────────────────────
# Azure subscription, tenant and identity to deploy into.
subscription_id = "your-subscription-id"
tenant_id       = "your-tenant-id"
client_id       = "your-service-principal-client-id"
user_object_id  = "your-user-object-id"

# ── Environment ───────────────────────────────────────────────────────────────
environment = "dev"
image_tag   = "dev"
location    = "eastus"

# ── Optional overrides ────────────────────────────────────────────────────────
# Leave commented to derive names from `environment` (e.g. rg-lefigaro-talk2data-dev).
# resource_group_name = ""
# openai_account_name = ""

# Model per deployment — default is gpt-4.1-mini for all three.
# schema_retrieval_model = "gpt-4.1-mini"
# sql_generation_model   = "gpt-4.1-mini"
# summary_model          = "gpt-4.1-mini"
